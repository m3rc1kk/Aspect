# Django
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=*
DJANGO_ENV=dev

# Database
POSTGRES_DB=aspect
POSTGRES_USER=aspect
POSTGRES_PASSWORD=aspect123
DB_HOST=db
DB_PORT=5432

# Frontend
FRONTEND_URL=http://localhost:5173

# Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/1
CHANNEL_LAYERS_REDIS=redis://redis:6379/2

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Logs (dev)
LOG_DIR=/app/logs

# Grafana (optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
